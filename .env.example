# ═══════════════════════════════════════════════════════════════════════
# Evil Origin Detection — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
#
# LOCAL DEVELOPMENT:
#   cp .env.example .env
#   Fill in your API keys below.
#
# RENDER DEPLOYMENT:
#   Do NOT commit .env to git.
#   Set each variable in:
#   Render Dashboard → Your Service → Environment → Environment Variables
#
# TOKEN ROTATION:
#   Each source accepts two keys (_KEY_1 and _KEY_2).
#   At runtime one is chosen randomly; if it fails the other is tried.
#   Using two keys doubles your free tier quota per source.
#   KEY_2 is optional — leave blank to use only KEY_1.
#
# ═══════════════════════════════════════════════════════════════════════

# ── App settings ──────────────────────────────────────────────────────
CACHE_TTL_HOURS=24
LOG_LEVEL=INFO
DB_PATH=./eod.db
LOG_PATH=./logs/eod.log

# ── VirusTotal ────────────────────────────────────────────────────────
# Get key: https://www.virustotal.com/gui/my-apikey
# Free: 500 requests/day | Supports: IP, Domain, Hash, URL
VT_KEY_1=
VT_KEY_2=

# ── AbuseIPDB ─────────────────────────────────────────────────────────
# Get key: https://www.abuseipdb.com/account/api
# Free: 1,000 requests/day | Supports: IP
ABUSEIPDB_KEY_1=
ABUSEIPDB_KEY_2=

# Free: 1,000 requests/month | Supports: IP

# ── Shodan ────────────────────────────────────────────────────────────
# Get key: https://account.shodan.io/
# Free: 100 requests/month | Supports: IP
SHODAN_KEY_1=
SHODAN_KEY_2=

# ── Pulsedive ─────────────────────────────────────────────────────────
# Get key: https://pulsedive.com/account/
# Free: 30 requests/day | Supports: IP, Domain, Hash, URL
PULSEDIVE_KEY_1=
PULSEDIVE_KEY_2=

# ── Criminal IP ───────────────────────────────────────────────────────
# Get key: https://www.criminalip.io/developer/api
# Free: 100 credits/day | Supports: IP, Domain, URL
CRIMINALIP_KEY_1=
CRIMINALIP_KEY_2=

# ── MalwareBazaar ─────────────────────────────────────────────────────
# No API key required — leave blank
# Unlimited free | Supports: Hash only
MALWAREBAZAAR_KEY_1=
MALWAREBAZAAR_KEY_2=

# ── URLScan.io ────────────────────────────────────────────────────────
# Get key: https://urlscan.io/user/
# Free: 100 scans/day | Supports: URL, Domain (+ screenshots)
URLSCAN_KEY_1=
URLSCAN_KEY_2=

# ── SecurityTrails ────────────────────────────────────────────────────
# Get key: https://app.securitytrails.com/corp/api
# Free: 50 requests/month | Supports: IP, Domain (WHOIS, DNS history)
SECURITYTRAILS_KEY_1=
SECURITYTRAILS_KEY_2=

# ── StopForumSpam ─────────────────────────────────────────────────────
# No API key required — leave blank
# Unlimited free | Supports: IP, Email
STOPFORUMSPAM_KEY_1=
STOPFORUMSPAM_KEY_2=

# ── WhatsMyName ───────────────────────────────────────────────────────
# No API key required — leave blank
# Uses public GitHub dataset | Supports: Email (username OSINT)
WHATSMYNAME_KEY_1=
WHATSMYNAME_KEY_2=
